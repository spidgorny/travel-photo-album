REDIS_URL=redis://127.0.0.1:6666
REDIS_FOLDER_CACHE_TTL_SECONDS=0

THUMB_KV_URL=redis://127.0.0.1:6666
THUMB_KV_PREFIX=travel-photo-album:thumb:v1
THUMB_TARGET_WIDTH=256
BULLMQ_REDIS_URL=redis://127.0.0.1:6379
THUMB_QUEUE_URL=redis://127.0.0.1:6379

# App/default search connection settings. Keep 127.0.0.1 for the local Next.js process;
# Docker services use the container-specific overrides below so they can reach the
# internal `typesense` service over the compose network.
TYPESENSE_PROTOCOL=http
TYPESENSE_HOST=127.0.0.1
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=change-me-typesense-key
TYPESENSE_COLLECTION=travel-photo-album-media
TYPESENSE_HEALTH_TIMEOUT_SECONDS=60

# Optional container-specific overrides for docker compose. Defaults already point at the
# internal kvrocks, redis, and typesense services, so these are usually only needed for
# custom setups.
MEDIA_WORKER_REDIS_URL=redis://kvrocks:6666
MEDIA_WORKER_THUMB_KV_URL=redis://kvrocks:6666
MEDIA_WORKER_BULLMQ_REDIS_URL=redis://redis:6379
MEDIA_WORKER_THUMB_QUEUE_URL=redis://redis:6379
MEDIA_WORKER_TYPESENSE_PROTOCOL=http
MEDIA_WORKER_TYPESENSE_HOST=typesense
MEDIA_WORKER_TYPESENSE_PORT=8108
MEDIA_WORKER_TYPESENSE_API_KEY=change-me-typesense-key
MEDIA_WORKER_TYPESENSE_COLLECTION=travel-photo-album-media
THUMB_QUEUE_NAME=thumb-jobs
THUMB_QUEUE_PREFIX=travel-photo-album
BULLMQ_WORKER_CONCURRENCY=2
# Optional: increase this if long thumbnail or metadata jobs lose their BullMQ lock.
BULLMQ_WORKER_LOCK_DURATION_MS=600000

DESCRIPTION_QUEUE_URL=redis://127.0.0.1:6379
DESCRIPTION_QUEUE_NAME=description-jobs
DESCRIPTION_QUEUE_PREFIX=travel-photo-album
DESCRIPTION_WORKER_CONCURRENCY=1
DESCRIPTION_WORKER_REDIS_URL=redis://kvrocks:6666
DESCRIPTION_WORKER_THUMB_KV_URL=redis://kvrocks:6666
DESCRIPTION_WORKER_QUEUE_URL=redis://redis:6379
DESCRIPTION_WORKER_TYPESENSE_PROTOCOL=http
DESCRIPTION_WORKER_TYPESENSE_HOST=typesense
DESCRIPTION_WORKER_TYPESENSE_PORT=8108
DESCRIPTION_WORKER_TYPESENSE_API_KEY=change-me-typesense-key
DESCRIPTION_WORKER_TYPESENSE_COLLECTION=travel-photo-album-media
DESCRIPTION_WORKER_OLLAMA_BASE_URL=http://127.0.0.1:11434
SEARCH_INDEXER_REDIS_URL=redis://kvrocks:6666
SEARCH_INDEXER_THUMB_KV_URL=redis://kvrocks:6666
SEARCH_INDEXER_TYPESENSE_PROTOCOL=http
SEARCH_INDEXER_TYPESENSE_HOST=typesense
SEARCH_INDEXER_TYPESENSE_PORT=8108
SEARCH_INDEXER_TYPESENSE_API_KEY=change-me-typesense-key
SEARCH_INDEXER_TYPESENSE_COLLECTION=travel-photo-album-media
# Rebuild/sync the search index every hour by default.
SEARCH_INDEX_INTERVAL_SECONDS=3600

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
# Optional override for the prompt used when auto-generating searchable image descriptions.
OLLAMA_CAPTION_PROMPT=

# Set this to a host path that exists on your machine and is shared with Docker Desktop.
# On macOS this is often under /Volumes/... rather than /media/...
MEDIA_ROOT_HOST_PATH=/Volumes/photo
MEDIA_ROOT_CONTAINER_PATH=/media/nas/photo
